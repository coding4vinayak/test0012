<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up - AI Code Roaster</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">
      <a href="/"><span class="logo">&gt;_</span> Code Roaster</a>
    </div>
    <div class="nav-links">
      <a href="/auth/login">Login</a>
    </div>
  </nav>

  <main class="container auth-page">
    <div class="auth-card">
      <h1>Create Account</h1>
      <p class="auth-subtitle">Save your roast history and share your shame</p>

      <% if (error) { %>
        <div class="error-message"><%= error %></div>
      <% } %>

      <form method="POST" action="/auth/register" class="auth-form">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="dev@example.com">
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required minlength="6" placeholder="Min 6 characters">
        </div>
        <button type="submit" class="btn btn-roast btn-full">Sign Up</button>
      </form>

      <p class="auth-switch">Already have an account? <a href="/auth/login">Login</a></p>
    </div>
  </main>
</body>
</html>
