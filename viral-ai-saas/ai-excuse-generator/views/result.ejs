<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Excuse - AI Excuse Generator</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand"><a href="/">AI Excuse Generator</a></div>
    <div class="nav-links">
      <% if (user) { %>
        <a href="/dashboard">Dashboard</a>
        <a href="/auth/logout">Logout</a>
      <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <section class="result-page">
    <h1>Your Excuse is Ready!</h1>

    <div class="excuse-card">
      <div class="excuse-category-badge"><%= excuse.category %></div>
      <div class="excuse-text"><%= excuse.data.excuse %></div>

      <div class="scores-row">
        <div class="score-item">
          <span class="score-label">Believability</span>
          <span class="score-value"><%= excuse.data.believabilityScore %>/10</span>
        </div>
        <div class="score-item">
          <span class="score-label">Creativity</span>
          <span class="score-value"><%= excuse.data.creativityScore %>/10</span>
        </div>
        <div class="score-item">
          <span class="score-label">Risk Level</span>
          <span class="risk-badge risk-<%= excuse.data.riskLevel %>"><%= excuse.data.riskLevel %></span>
        </div>
      </div>

      <div class="delivery-tips">
        <h3>Delivery Tips</h3>
        <p><%= excuse.data.deliveryTips %></p>
      </div>
    </div>

    <div class="share-buttons">
      <button class="btn-share btn-twitter" onclick="shareTwitter()">Share on Twitter</button>
      <button class="btn-share btn-whatsapp" onclick="shareWhatsApp()">Share on WhatsApp</button>
      <button class="btn-share btn-copy" onclick="copyLink()">Copy Link</button>
    </div>

    <a href="/" class="btn-generate">Generate Another Excuse</a>
  </section>

  <script src="/js/app.js"></script>
</body>
</html>
