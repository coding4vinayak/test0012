<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Website Roast - AI Roast My Website</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/" class="nav-brand">Roast My Website</a>
    <div class="nav-links">
      <a href="/" class="roast-btn-sm">Roast Your Website</a>
    </div>
  </nav>

  <div class="share-page">
    <div class="roast-card">
      <h1>Website Roast Card</h1>
      <p class="roasted-url">Target: <strong><%= roast.url %></strong></p>

      <div class="scores-grid">
        <div class="score-card">
          <h3>Design</h3>
          <div class="score-meter" data-score="<%= roast.data.design.score %>">
            <span class="score-value"><%= roast.data.design.score %>/10</span>
          </div>
          <p class="score-liner"><%= roast.data.design.oneLiner %></p>
        </div>

        <div class="score-card">
          <h3>Copy</h3>
          <div class="score-meter" data-score="<%= roast.data.copy.score %>">
            <span class="score-value"><%= roast.data.copy.score %>/10</span>
          </div>
          <p class="score-liner"><%= roast.data.copy.oneLiner %></p>
        </div>

        <div class="score-card">
          <h3>UX</h3>
          <div class="score-meter" data-score="<%= roast.data.ux.score %>">
            <span class="score-value"><%= roast.data.ux.score %>/10</span>
          </div>
          <p class="score-liner"><%= roast.data.ux.oneLiner %></p>
        </div>
      </div>

      <div class="overall-verdict">
        <h2>Overall: <%= roast.data.overall.score %>/10</h2>
        <p><%= roast.data.overall.verdict %></p>
      </div>
    </div>

    <div class="cta-section">
      <h2>Think your website can do better?</h2>
      <a href="/" class="roast-btn">Get Your Website Roasted</a>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
