<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - LinkSnap</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="logo">LinkSnap</a>
      <div class="nav-links">
        <a href="/dashboard">Dashboard</a>
        <a href="/auth/logout">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container dashboard">
    <h1>Your Links</h1>

    <div class="create-link-card">
      <h3>Create New Short Link</h3>
      <form id="create-link-form" class="create-link-form">
        <div class="form-row">
          <div class="form-group flex-grow">
            <label for="url">URL to shorten</label>
            <input type="url" id="url" name="url" required placeholder="https://example.com/very/long/url">
          </div>
          <div class="form-group">
            <label for="custom_code">Custom alias (optional)</label>
            <input type="text" id="custom_code" name="custom_code" placeholder="my-link">
          </div>
        </div>
        <div class="form-group">
          <label for="title">Title (optional)</label>
          <input type="text" id="title" name="title" placeholder="My awesome link">
        </div>
        <button type="submit" class="btn btn-primary">Shorten URL</button>
      </form>
      <div id="create-result" class="create-result" style="display: none;"></div>
    </div>

    <div class="links-table-container">
      <table class="links-table">
        <thead>
          <tr>
            <th>Title / URL</th>
            <th>Short Link</th>
            <th>Clicks</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (links.length === 0) { %>
            <tr><td colspan="5" class="empty-state">No links yet. Create your first short link above!</td></tr>
          <% } %>
          <% links.forEach(link => { %>
            <tr>
              <td class="link-info">
                <div class="link-title"><%= link.title || 'Untitled' %></div>
                <div class="link-url"><%= link.original_url %></div>
              </td>
              <td><a href="/<%= link.short_code %>" class="short-link">/<%= link.short_code %></a></td>
              <td class="click-count"><%= link.click_count %></td>
              <td><%= new Date(link.created_at).toLocaleDateString() %></td>
              <td class="actions">
                <a href="/analytics/<%= link.id %>" class="btn btn-sm btn-secondary">Analytics</a>
                <button class="btn btn-sm btn-danger delete-link" data-id="<%= link.id %>">Delete</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    document.getElementById('create-link-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      const url = document.getElementById('url').value;
      const custom_code = document.getElementById('custom_code').value;
      const title = document.getElementById('title').value;

      try {
        const res = await fetch('/links/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url, custom_code, title })
        });
        const data = await res.json();
        if (data.success) {
          window.location.reload();
        } else {
          document.getElementById('create-result').style.display = 'block';
          document.getElementById('create-result').textContent = data.error;
          document.getElementById('create-result').className = 'create-result error';
        }
      } catch (err) {
        alert('Failed to create link');
      }
    });

    document.querySelectorAll('.delete-link').forEach(btn => {
      btn.addEventListener('click', async function() {
        if (!confirm('Delete this link?')) return;
        const id = this.dataset.id;
        const res = await fetch('/links/' + id, { method: 'DELETE' });
        if (res.ok) {
          window.location.reload();
        }
      });
    });
  </script>
</body>
</html>
