<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Screenshot & PDF API - Capture, Convert, Deliver</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">ScreenPDF<span>API</span></a>
      <div class="nav-links">
        <% if (user) { %>
          <a href="/dashboard">Dashboard</a>
          <a href="/playground">Playground</a>
          <a href="/auth/logout">Logout</a>
        <% } else { %>
          <a href="/auth/login">Login</a>
          <a href="/auth/register" class="btn btn-primary">Get Started</a>
        <% } %>
      </div>
    </div>
  </nav>

  <section class="hero">
    <div class="container">
      <h1>Screenshot & PDF Generation API</h1>
      <p class="hero-subtitle">Capture website screenshots and generate PDFs with a simple REST API. Built for developers.</p>
      <div class="hero-actions">
        <a href="/auth/register" class="btn btn-primary btn-lg">Get Free API Key</a>
        <a href="#docs" class="btn btn-outline btn-lg">View Documentation</a>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <h2>API Features</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">&#128247;</div>
          <h3>Screenshot Capture</h3>
          <p>Capture full-page screenshots of any URL with custom viewport settings.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128196;</div>
          <h3>PDF Generation</h3>
          <p>Generate PDFs from HTML content or URLs with configurable page settings.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#9889;</div>
          <h3>Fast & Reliable</h3>
          <p>Low-latency API with high availability. Process requests in seconds.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128272;</div>
          <h3>Secure API Keys</h3>
          <p>Manage multiple API keys with per-key usage tracking and rate limiting.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pricing" id="pricing">
    <div class="container">
      <h2>Simple Pricing</h2>
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Free</h3>
          <div class="price">$0<span>/month</span></div>
          <ul>
            <li>100 requests/hour</li>
            <li>Screenshot & PDF APIs</li>
            <li>1 API key</li>
            <li>Community support</li>
          </ul>
          <a href="/auth/register" class="btn btn-outline">Get Started</a>
        </div>
        <div class="pricing-card featured">
          <h3>Pro</h3>
          <div class="price">$29<span>/month</span></div>
          <ul>
            <li>10,000 requests/hour</li>
            <li>All API endpoints</li>
            <li>Unlimited API keys</li>
            <li>Priority support</li>
            <li>Custom viewport sizes</li>
          </ul>
          <a href="/auth/register" class="btn btn-primary">Start Free Trial</a>
        </div>
        <div class="pricing-card">
          <h3>Enterprise</h3>
          <div class="price">Custom</div>
          <ul>
            <li>Unlimited requests</li>
            <li>Dedicated infrastructure</li>
            <li>SLA guarantee</li>
            <li>24/7 support</li>
            <li>Custom integrations</li>
          </ul>
          <a href="#" class="btn btn-outline">Contact Sales</a>
        </div>
      </div>
    </div>
  </section>

  <section class="docs" id="docs">
    <div class="container">
      <h2>Quick Start</h2>
      <div class="docs-content">
        <div class="code-example">
          <h3>Screenshot API</h3>
          <pre><code>curl -X POST https://api.screenpdf.dev/api/screenshot \
  -H "X-API-Key: your_api_key" \
  -H "Content-Type: application/json" \
  -d '{
    "url": "https://example.com",
    "width": 1280,
    "height": 720,
    "format": "png"
  }' --output screenshot.png</code></pre>
        </div>
        <div class="code-example">
          <h3>PDF Generation API</h3>
          <pre><code>curl -X POST https://api.screenpdf.dev/api/pdf \
  -H "X-API-Key: your_api_key" \
  -H "Content-Type: application/json" \
  -d '{
    "html": "&lt;h1&gt;Hello World&lt;/h1&gt;&lt;p&gt;Generated PDF&lt;/p&gt;",
    "title": "My Document",
    "pageSize": "A4"
  }' --output document.pdf</code></pre>
        </div>
        <div class="code-example">
          <h3>Node.js Example</h3>
          <pre><code>const response = await fetch('https://api.screenpdf.dev/api/pdf', {
  method: 'POST',
  headers: {
    'X-API-Key': 'your_api_key',
    'Content-Type': 'application/json'
  },
  body: JSON.stringify({
    url: 'https://example.com',
    pageSize: 'A4'
  })
});
const pdf = await response.arrayBuffer();
fs.writeFileSync('output.pdf', Buffer.from(pdf));</code></pre>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2024 ScreenPDF API. Built for developers.</p>
    </div>
  </footer>
</body>
</html>
