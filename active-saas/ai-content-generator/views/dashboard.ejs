<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - AI Content Generator</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">AI Content Generator</a>
      <div class="nav-links">
        <span class="user-email"><%= user.email %></span>
        <a href="/auth/logout" class="btn btn-outline">Logout</a>
      </div>
    </div>
  </nav>

  <main class="dashboard">
    <div class="container">
      <h1>Content Generator</h1>

      <div class="generator-section">
        <form id="generate-form" class="generate-form">
          <div class="form-group">
            <label for="type">Content Type</label>
            <select id="type" name="type" required>
              <option value="blog">Blog Post</option>
              <option value="social">Social Media</option>
              <option value="email">Professional Email</option>
            </select>
          </div>
          <div class="form-group">
            <label for="prompt">What would you like to write about?</label>
            <textarea id="prompt" name="prompt" rows="3" placeholder="Enter your topic or describe what you need..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" id="generate-btn">Generate Content</button>
        </form>

        <div id="output-section" class="output-section" style="display: none;">
          <h2>Generated Content</h2>
          <div id="output-content" class="output-content"></div>
          <button id="copy-btn" class="btn btn-secondary">Copy to Clipboard</button>
        </div>
      </div>

      <section class="history-section">
        <h2>Content History</h2>
        <% if (contents.length === 0) { %>
          <p class="empty-state">No content generated yet. Try creating something above!</p>
        <% } else { %>
          <div class="history-grid">
            <% contents.forEach(function(content) { %>
              <div class="history-card" data-id="<%= content.id %>">
                <div class="history-header">
                  <span class="history-type"><%= content.type %></span>
                  <span class="history-date"><%= new Date(content.created_at).toLocaleDateString() %></span>
                </div>
                <p class="history-prompt"><strong>Prompt:</strong> <%= content.prompt %></p>
                <p class="history-preview"><%= content.result.substring(0, 150) %>...</p>
                <button class="btn btn-secondary btn-small view-content" data-result="<%= encodeURIComponent(content.result) %>">View Full</button>
              </div>
            <% }); %>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <script src="/js/app.js"></script>
</body>
</html>
