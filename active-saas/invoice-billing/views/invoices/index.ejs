<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoices - InvoiceFlow</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="logo">InvoiceFlow</a>
      <div class="nav-links">
        <a href="/dashboard">Dashboard</a>
        <a href="/clients">Clients</a>
        <a href="/invoices" class="active">Invoices</a>
        <a href="/auth/logout" class="btn btn-outline">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="page-header">
      <h1>Invoices</h1>
      <a href="/invoices/new" class="btn btn-primary">Create Invoice</a>
    </div>

    <% if (invoices.length === 0) { %>
      <p class="empty-state">No invoices yet. <a href="/invoices/new">Create your first invoice</a></p>
    <% } else { %>
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Invoice #</th>
            <th>Client</th>
            <th>Status</th>
            <th>Due Date</th>
            <th>Amount</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% invoices.forEach(inv => { %>
          <tr>
            <td><%= inv.invoice_number %></td>
            <td><%= inv.client_name %></td>
            <td><span class="status-badge status-<%= inv.status %>"><%= inv.status %></span></td>
            <td><%= inv.due_date %></td>
            <td>$<%= inv.total.toFixed(2) %></td>
            <td>
              <a href="/invoices/<%= inv.id %>" class="btn btn-small">View</a>
              <a href="/invoices/<%= inv.id %>/pdf" class="btn btn-small">PDF</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</body>
</html>
